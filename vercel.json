{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/super-admin",
      "destination": "/index.html"
    },
    {
      "source": "/purchases",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api).*)" ,
      "destination": "/index.html"
    }
  ]
}
