{
  "cleanUrls": true,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/super-admin",
      "destination": "/index.html"
    },
    {
      "source": "/purchases",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
